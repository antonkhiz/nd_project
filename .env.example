SPOTIPY_CLIENT_ID=your_client_id
SPOTIPY_CLIENT_SECRET=your_client_secret
SPOTIPY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Set to 1 once if you changed scopes or need a clean consent screen; then set back to 0.
SPOTIFY_AUTH_SHOW_DIALOG=0

# Optional tuning (only if your Spotify app can call /audio-features; many new apps get 403):
# The algorithm tries to keep vocals low and instrumental parts higher.
SPOTIFY_MAX_SPEECHINESS=0.08
SPOTIFY_MIN_INSTRUMENTALNESS=0.6
SPOTIFY_TRACK_LIMIT=30

# ISO market for catalog (Spotify API `market`, not the old `country` query param).
# Use your account region if US gives empty or odd results.
SPOTIFY_COUNTRY=US

# How deep to scan the artist discography (album + single). More = slower, more variety.
SPOTIFY_MAX_ALBUMS=40
# Spotify caps "artist albums" at limit<=10 per request; do not raise above 10.
SPOTIFY_ARTIST_ALBUMS_PAGE=10
# Upper bound on tracks passed to audio-features scoring (API batches of 100).
SPOTIFY_CATALOG_TRACK_CAP=450
